pipeline {
    agent any 

    environment{
        AWS_DEFAULT_REGION = 'ap-south-1'
    }

    stages{
        stage (AWS_INSTANCE) {
            steps{
                scripts {
                    instanceId = sh(script: "curl -s http://43.205.232.184", returnStdout: true).trim()
                    echo "Running on instance: ${instanceId}"

                    userName = sh(script: "whoami", returnStdout: true).trim()
                    echo "Jenkins is running as user: ${userName}"                
                }
            }
        }
    }



}


