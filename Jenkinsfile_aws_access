pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-1"
    }

    stages {
        stage('Get Instance Metadata') {
            steps {
                sh'''
                    aws sts get-caller-identity

                    USERNAME=$(aws sts get-caller-identity --query Arn --output text | awk -F/ '{print $NF}')

                    echo "AWS User: $USERNAME"
                '''
            }
        }
    }
}